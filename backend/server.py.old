from dotenv import load_dotenv
from pathlib import Path

ROOT_DIR = Path(__file__).parent
load_dotenv(ROOT_DIR / '.env')

import os
import logging
import uuid
import bcrypt
import jwt
import secrets
import random
from datetime import datetime, timezone, timedelta
from typing import List, Optional, Literal
from cryptography.fernet import Fernet, InvalidToken

from fastapi import FastAPI, APIRouter, HTTPException, Depends, Request
from fastapi.security import HTTPBearer, HTTPAuthorizationCredentials
from starlette.middleware.cors import CORSMiddleware
from motor.motor_asyncio import AsyncIOMotorClient
from pydantic import BaseModel, Field, EmailStr

# ----- Setup -----
mongo_url = os.environ['MONGO_URI']
client = AsyncIOMotorClient(mongo_url)
db = client[os.environ['DATABASE_NAME']]

JWT_SECRET = os.environ['JWT_SECRET']
JWT_ALG = "HS256"
ENCRYPTION_KEY = os.environ.get("ENCRYPTION_KEY", "")

cipher_suite = Fernet(ENCRYPTION_KEY.encode()) if ENCRYPTION_KEY else None

def encrypt_data(text: str) -> str:
    if not text or not cipher_suite:
        return text
    return cipher_suite.encrypt(text.encode()).decode()

def decrypt_data(text: str) -> str:
    if not text or not cipher_suite:
        return text
    try:
        return cipher_suite.decrypt(text.encode()).decode()
    except (InvalidToken, ValueError, TypeError):
        return text

def encrypt_user(u: dict) -> dict:
    res = u.copy()
    if res.get("full_name"): res["full_name"] = encrypt_data(res["full_name"])
    if res.get("phone"): res["phone"] = encrypt_data(res["phone"])
    return res

def decrypt_user(u: dict) -> dict:
    if not u: return u
    res = u.copy()
    if res.get("full_name"): res["full_name"] = decrypt_data(res["full_name"])
    if res.get("phone"): res["phone"] = decrypt_data(res["phone"])
    return res

app = FastAPI(title="Cargo Tracker API")
api = APIRouter(prefix="/api")
auth_scheme = HTTPBearer(auto_error=False)

# ----- Helpers -----
def hash_password(p: str) -> str:
    return bcrypt.hashpw(p.encode(), bcrypt.gensalt()).decode()

def verify_password(p: str, h: str) -> bool:
    try:
        return bcrypt.checkpw(p.encode(), h.encode())
    except Exception:
        return False

def create_token(user_id: str, ttype: str = "access") -> str:
    delta = timedelta(minutes=60) if ttype == "access" else timedelta(days=30)
    payload = {"sub": user_id, "type": ttype, "exp": datetime.now(timezone.utc) + delta}
    return jwt.encode(payload, JWT_SECRET, algorithm=JWT_ALG)

def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()

async def get_current_user(creds: Optional[HTTPAuthorizationCredentials] = Depends(auth_scheme)) -> dict:
    if not creds:
        raise HTTPException(401, "Not authenticated")
    try:
        payload = jwt.decode(creds.credentials, JWT_SECRET, algorithms=[JWT_ALG])
        user = await db.users.find_one({"id": payload["sub"]}, {"_id": 0, "password_hash": 0})
        if not user:
            raise HTTPException(401, "User not found")
        return decrypt_user(user)
    except jwt.ExpiredSignatureError:
        raise HTTPException(401, "Token expired")
    except jwt.InvalidTokenError:
        raise HTTPException(401, "Invalid token")

# ----- Models -----
class RegisterIn(BaseModel):
    full_name: str
    email: EmailStr
    phone: str
    password: str
    city: str
    preferred_language: Literal["fr", "en", "zh"] = "fr"

class LoginIn(BaseModel):
    email: EmailStr
    password: str

class ForgotIn(BaseModel):
    email: EmailStr

class VerifyOtpIn(BaseModel):
    email: EmailStr
    code: str

class ResetIn(BaseModel):
    email: EmailStr
    code: str
    new_password: str

class UpdateProfileIn(BaseModel):
    full_name: Optional[str] = None
    phone: Optional[str] = None
    city: Optional[str] = None
    default_delivery_address: Optional[str] = None
    preferred_language: Optional[Literal["fr", "en", "zh"]] = None
    avatar_url: Optional[str] = None

class RefreshIn(BaseModel):
    refresh: str

class PushTokenIn(BaseModel):
    token: str
    platform: Literal["ios", "android", "web"] = "android"

class ColisIn(BaseModel):
    description: str
    category: str
    transport_mode: Literal["air", "sea"]
    weight_real: float = 0.0
    weight_volumetric: float = 0.0
    dimensions: dict = Field(default_factory=lambda: {"l": 0, "w": 0, "h": 0})
    declared_value: float = 0
    currency: Literal["CNY", "USD"] = "CNY"
    supplier_name: str
    platform: str
    order_ref: Optional[str] = ""
    insurance_enabled: bool = False
    delivery_address: Optional[str] = ""
    instructions: Optional[str] = ""
    invoice_base64: Optional[str] = None
    photos: Optional[List[str]] = None

# ----- Auth Endpoints -----
@api.post("/auth/register")
async def register(body: RegisterIn):
    email = body.email.lower().strip()
    if await db.users.find_one({"email": email}):
        raise HTTPException(400, "Email already registered")
    user_id = str(uuid.uuid4())
    # Generate client code: CM + 5 digits
    count = await db.users.count_documents({})
    client_code = f"CM{(count + 124):05d}"
    user_doc = encrypt_user({
        "id": user_id,
        "full_name": body.full_name,
        "email": email,
        "phone": body.phone,
        "city": body.city,
        "client_code": client_code,
        "password_hash": hash_password(body.password),
        "default_delivery_address": "",
        "preferred_language": body.preferred_language,
        "avatar_url": None,
        "role": "client",
        "created_at": now_iso(),
    })
    await db.users.insert_one(user_doc)
    user_doc.pop("password_hash", None)
    user_doc.pop("_id", None)
    user_doc = decrypt_user(user_doc)
    access = create_token(user_id, "access")
    refresh = create_token(user_id, "refresh")
    return {"access": access, "refresh": refresh, "user": user_doc}

@api.post("/auth/login")
async def login(body: LoginIn):
    email = body.email.lower().strip()
    user = await db.users.find_one({"email": email})
    if not user or not verify_password(body.password, user.get("password_hash", "")):
        raise HTTPException(401, "Invalid credentials")
    access = create_token(user["id"], "access")
    refresh = create_token(user["id"], "refresh")
    user.pop("_id", None)
    user.pop("password_hash", None)
    return {"access": access, "refresh": refresh, "user": decrypt_user(user)}

@api.post("/auth/push-token")
async def register_push_token(body: PushTokenIn, user: dict = Depends(get_current_user)):
    await db.users.update_one(
        {"id": user["id"]},
        {"$set": {"push_token": body.token, "push_platform": body.platform}}
    )
    return {"message": "Push token registered successfully"}

@api.get("/auth/me")
async def me(user: dict = Depends(get_current_user)):
    return user

@api.post("/auth/qr-login")
async def qr_login(qr_token: str):
    # Lookup by badge_secret (or email for fallback)
    user = await db.users.find_one({"$or": [{"badge_secret": qr_token}, {"email": qr_token}]})
    if not user or user.get("role") not in ["operator", "admin"]:
        raise HTTPException(404, "Badge invalide ou non reconnu.")
    
    otp = f"{random.randint(1000, 9999)}"
    await db.password_resets.update_one(
        {"email": user["email"]},
        {"$set": {"code": otp, "expires_at": (datetime.now(timezone.utc) + timedelta(minutes=10)).isoformat(), "used": False}},
        upsert=True
    )
    logger.info(f"[OTP OPERATOR] {user['email']} -> {otp}")
    return {"message": "OTP envoyé", "email": user["email"]}

@api.post("/auth/qr-verify")
async def qr_verify(body: VerifyOtpIn):
    email = body.email.lower().strip()
    rec = await db.password_resets.find_one({"email": email})
    if not rec or rec.get("code") != body.code or rec.get("used"):
        raise HTTPException(400, "Code invalide")
    
    user = await db.users.find_one({"email": email})
    if not user:
        raise HTTPException(404, "User not found")
        
    await db.password_resets.update_one({"email": email}, {"$set": {"used": True}})
    access = create_token(user["id"], "access")
    refresh = create_token(user["id"], "refresh")
    user.pop("_id", None)
    user.pop("password_hash", None)
    return {"access": access, "refresh": refresh, "user": decrypt_user(user)}

@api.post("/auth/forgot-password")
async def forgot(body: ForgotIn):
    email = body.email.lower().strip()
    user = await db.users.find_one({"email": email})
    # Always return success for privacy. Generate code anyway.
    code = f"{random.randint(100000, 999999)}"
    if user:
        await db.password_resets.update_one(
            {"email": email},
            {"$set": {"code": code, "expires_at": (datetime.now(timezone.utc) + timedelta(minutes=10)).isoformat(), "used": False}},
            upsert=True,
        )
        logger.info(f"[OTP] {email} -> {code}")
    return {"ok": True, "dev_code": code if user else None}

@api.post("/auth/verify-otp")
async def verify_otp(body: VerifyOtpIn):
    email = body.email.lower().strip()
    rec = await db.password_resets.find_one({"email": email})
    if not rec or rec.get("code") != body.code or rec.get("used"):
        raise HTTPException(400, "Invalid code")
    return {"ok": True}

@api.post("/auth/reset-password")
async def reset_password(body: ResetIn):
    email = body.email.lower().strip()
    rec = await db.password_resets.find_one({"email": email})
    if not rec or rec.get("code") != body.code or rec.get("used"):
        raise HTTPException(400, "Invalid code")
    await db.users.update_one({"email": email}, {"$set": {"password_hash": hash_password(body.new_password)}})
    await db.password_resets.update_one({"email": email}, {"$set": {"used": True}})
    return {"ok": True}

@api.put("/auth/me")
async def update_me(body: UpdateProfileIn, user: dict = Depends(get_current_user)):
    updates = {k: v for k, v in body.model_dump().items() if v is not None}
    if updates:
        encrypted_updates = encrypt_user(updates)
        await db.users.update_one({"id": user["id"]}, {"$set": encrypted_updates})
    fresh = await db.users.find_one({"id": user["id"]}, {"_id": 0, "password_hash": 0})
    return decrypt_user(fresh)

@api.post("/auth/refresh")
async def refresh_token(body: RefreshIn):
    try:
        payload = jwt.decode(body.refresh, JWT_SECRET, algorithms=[JWT_ALG])
        if payload.get("type") != "refresh":
            raise HTTPException(401, "Invalid token type")
        user = await db.users.find_one({"id": payload["sub"]}, {"_id": 0, "password_hash": 0})
        if not user:
            raise HTTPException(401, "User not found")
        return {"access": create_token(user["id"], "access"), "user": decrypt_user(user)}
    except jwt.ExpiredSignatureError:
        raise HTTPException(401, "Refresh token expired")
    except jwt.InvalidTokenError:
        raise HTTPException(401, "Invalid refresh token")

@api.post("/auth/push-token")
async def register_push_token(body: PushTokenIn, user: dict = Depends(get_current_user)):
    await db.push_tokens.update_one(
        {"user_id": user["id"], "token": body.token},
        {"$set": {"user_id": user["id"], "token": body.token, "platform": body.platform, "updated_at": now_iso()}},
        upsert=True,
    )
    return {"ok": True}

# ----- Colis Endpoints -----
TIMELINE_ORDER = ["pending_reception", "received", "quoted", "grouped", "loading", "departed", "in_transit", "arrived", "delivered"]

def build_timeline(status: str, created_at: str) -> List[dict]:
    cur_idx = TIMELINE_ORDER.index(status) if status in TIMELINE_ORDER else 0
    steps = []
    for i, s in enumerate(TIMELINE_ORDER):
        if i < cur_idx:
            steps.append({"step": s, "completed_at": created_at, "status": "done"})
        elif i == cur_idx:
            steps.append({"step": s, "completed_at": created_at, "status": "current"})
        else:
            steps.append({"step": s, "completed_at": None, "status": "pending"})
    return steps

@api.get("/colis")
async def list_colis(user: dict = Depends(get_current_user)):
    if user.get("role") in ["admin", "operator"]:
        items = await db.colis.find({}, {"_id": 0}).sort("created_at", -1).to_list(500)
        user_ids = list(set(i["user_id"] for i in items))
        users_info = await db.users.find({"id": {"$in": user_ids}}, {"id": 1, "full_name": 1, "_id": 0}).to_list(None)
        user_map = {u["id"]: decrypt_data(u.get("full_name", "")) for u in users_info}
        for item in items:
            item["client_name"] = user_map.get(item["user_id"], "Inconnu")
    else:
        items = await db.colis.find({"user_id": user["id"]}, {"_id": 0}).sort("created_at", -1).to_list(500)
    return items

# ----- Admin Endpoints -----
@api.get("/admin/stats")
async def admin_stats(user: dict = Depends(get_current_user)):
    if user.get("role") != "admin":
        raise HTTPException(403, "Forbidden")
    total_packages = await db.colis.count_documents({})
    total_revenue = await db.colis.aggregate([{"$group": {"_id": None, "total": {"$sum": "$declared_value"}}}]).to_list(1)
    rev = total_revenue[0]["total"] if total_revenue else 0
    return {
        "total_revenue": rev,
        "total_packages": total_packages,
        "logistics_split": {"sea": 5, "air": 2}
    }

@api.get("/admin/customers")
async def admin_list_customers(user: dict = Depends(get_current_user)):
    if user.get("role") != "admin":
        raise HTTPException(403, "Forbidden")
    users = await db.users.find({"role": "client"}, {"_id": 0, "password_hash": 0}).to_list(500)
    return [decrypt_user(u) for u in users]

@api.get("/admin/team")
async def admin_list_team(user: dict = Depends(get_current_user)):
    if user.get("role") != "admin":
        raise HTTPException(403, "Forbidden")
    users = await db.users.find({"role": {"$in": ["admin", "operator"]}}, {"_id": 0, "password_hash": 0}).to_list(100)
    return [decrypt_user(u) for u in users]

class AdminUpdateUserIn(BaseModel):
    full_name: Optional[str] = None
    email: Optional[str] = None
    phone: Optional[str] = None
    city: Optional[str] = None
    role: Optional[Literal["admin", "operator", "client"]] = None

@api.patch("/admin/users/{uid}")
async def admin_update_user(uid: str, body: AdminUpdateUserIn, user: dict = Depends(get_current_user)):
    if user.get("role") != "admin":
        raise HTTPException(403, "Forbidden")
        
    update_data = body.model_dump(exclude_unset=True)
    if not update_data:
        u = await db.users.find_one({"id": uid}, {"_id": 0, "password_hash": 0})
        return decrypt_user(u)
        
    if "email" in update_data:
        update_data["email"] = update_data["email"].lower().strip()
        
    encrypted_update = encrypt_user(update_data)
        
    res = await db.users.update_one({"id": uid}, {"$set": encrypted_update})
    if res.matched_count == 0:
        raise HTTPException(404, "User not found")
        
    u = await db.users.find_one({"id": uid}, {"_id": 0, "password_hash": 0})
    return decrypt_user(u)

# ----- Settings & Config Endpoints -----
class SettingsIn(BaseModel):
    storage_free_days: int = 7
    storage_daily_fee: float = 1000.0
    air_delay_days: int = 7
    air_express_delay_days: int = 3
    sea_delay_days: int = 45
    exchange_rate_cny_xaf: float = 85.0

@api.get("/admin/settings")
async def get_settings(user: dict = Depends(get_current_user)):
    # Accessible to operator and admin for calculations
    if user.get("role") not in ["admin", "operator"]:
        raise HTTPException(403, "Forbidden")
    settings = await db.settings.find_one({"_id": "global_config"})
    if not settings:
        settings = SettingsIn().model_dump()
        settings["_id"] = "global_config"
        await db.settings.insert_one(settings)
    settings.pop("_id", None)
    return settings

@api.put("/admin/settings")
async def update_settings(body: SettingsIn, user: dict = Depends(get_current_user)):
    if user.get("role") != "admin":
        raise HTTPException(403, "Forbidden")
    
    current_settings = await db.settings.find_one({"_id": "global_config"})
    if current_settings and current_settings.get("exchange_rate_cny_xaf") != body.exchange_rate_cny_xaf:
        # Save history if rate changed
        await db.exchange_rates_history.insert_one({
            "old_rate": current_settings.get("exchange_rate_cny_xaf"),
            "new_rate": body.exchange_rate_cny_xaf,
            "changed_at": now_iso(),
            "changed_by": user["id"]
        })

    update_data = body.model_dump()
    await db.settings.update_one({"_id": "global_config"}, {"$set": update_data}, upsert=True)
    return update_data

